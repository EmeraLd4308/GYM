generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BaseLift {
  NONE
  BENCH
  SQUAT
  DEADLIFT
}

enum GlSex {
  MALE
  FEMALE
}

enum GlEquipment {
  CLASSIC
  EQUIPPED
}

enum GlDiscipline {
  POWERLIFTING
  BENCH_ONLY
}

model User {
  id        String   @id @default(cuid())
  login     String   @unique
  createdAt DateTime @default(now())

  avatarId String @default("barbell") @db.VarChar(32)
  nickname String? @db.VarChar(40)

  glBodyweightKg  Decimal?    @db.Decimal(8, 3)
  glMaxSquatKg    Decimal?    @db.Decimal(12, 4)
  glMaxBenchKg    Decimal?    @db.Decimal(12, 4)
  glMaxDeadliftKg Decimal?    @db.Decimal(12, 4)
  glSex           GlSex?
  glEquipment     GlEquipment?
  glDiscipline    GlDiscipline?

  sessions               Session[]
  templates              WorkoutTemplate[]
  workouts               Workout[]
  profileSbdMaxSnapshots ProfileSbdMaxSnapshot[]
}

model ProfileSbdMaxSnapshot {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordedAt DateTime @default(now())
  squatKg    Decimal? @db.Decimal(12, 4)
  benchKg    Decimal? @db.Decimal(12, 4)
  deadliftKg Decimal? @db.Decimal(12, 4)

  @@index([userId, recordedAt])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model WorkoutTemplate {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  exercises TemplateExercise[]
  createdAt DateTime           @default(now())

  @@index([userId])
}

model TemplateExercise {
  id         String          @id @default(cuid())
  templateId String
  template   WorkoutTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sortOrder  Int
  name       String
  baseLift   BaseLift        @default(NONE)

  @@index([templateId])
}

model Workout {
  id         String            @id @default(cuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       DateTime          @default(now())
  title      String?
  notes      String?           @db.Text
  templateId String?
  exercises  WorkoutExercise[]
  createdAt  DateTime          @default(now())

  @@index([userId])
  @@index([date])
}

model WorkoutExercise {
  id        String         @id @default(cuid())
  workoutId String
  workout   Workout        @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  sortOrder Int
  name      String
  baseLift  BaseLift       @default(NONE)
  planDone  Boolean        @default(false)
  sets      ExerciseSet[]

  @@index([workoutId])
}

model ExerciseSet {
  id                  String          @id @default(cuid())
  workoutExerciseId String
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
  sortOrder           Int
  weightKg            Decimal         @db.Decimal(12, 4)
  reps                Int
  isWarmup            Boolean         @default(false)
  rpe                 Decimal?        @db.Decimal(4, 2)

  @@index([workoutExerciseId])
}
